# ─────────────────────────────────────────────────────────────────────────────
# WA-Business-Selfhosted — environment variables
#
# Copy this file to `.env` and fill in your values. NEVER commit your real
# `.env` — it is gitignored. The server refuses to boot if required vars
# (marked REQUIRED below) are missing.
# ─────────────────────────────────────────────────────────────────────────────

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED — the server will not start without these
# ═════════════════════════════════════════════════════════════════════════════

# Database password. The user, host, port, and database name default to
# whatsapp / 127.0.0.1 / 5432 / whatsapp_messages but can be overridden below.
DB_PASSWORD=

# Bearer token clients must send in `Authorization: Bearer <token>` to call any
# /api/* endpoint. Generate a long random string (≥ 32 bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=

# Meta App secret used to verify incoming webhook signatures (X-Hub-Signature-256).
# Find it under Meta App Dashboard → Settings → Basic → App Secret.
META_APP_SECRET=

# Meta webhook verification token. You set this yourself in the Meta App
# Dashboard when configuring the webhook subscription; it can be any string.
WHATSAPP_VERIFY_TOKEN=

# Allowed origins for CORS, comma-separated. No wildcard fallback — if this is
# empty the server refuses to start. Set the origin(s) of any browser app that
# will call this gateway (e.g., your inbox UI).
CORS_ORIGIN=https://your-inbox-ui.example.com

# ═════════════════════════════════════════════════════════════════════════════
# WhatsApp Cloud API credentials (REQUIRED for sending messages)
# ═════════════════════════════════════════════════════════════════════════════

# Long-lived access token from a Meta System User. Do NOT use a short-lived
# user token. See docs/meta-setup.md for the step-by-step.
WHATSAPP_ACCESS_TOKEN=

# The phone-number ID of your WhatsApp Business number (Meta App Dashboard →
# WhatsApp → API Setup).
WHATSAPP_PHONE_NUMBER_ID=

# WABA (WhatsApp Business Account) ID, used for template management endpoints.
WHATSAPP_WABA_ID=

# ═════════════════════════════════════════════════════════════════════════════
# Database (OPTIONAL overrides — defaults shown)
# ═════════════════════════════════════════════════════════════════════════════

#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_NAME=whatsapp_messages
#DB_USER=whatsapp

# ═════════════════════════════════════════════════════════════════════════════
# Server (OPTIONAL)
# ═════════════════════════════════════════════════════════════════════════════

# HTTP port to bind.
PORT=3100

# Where inbound media files are stored on disk. The path must be writable by
# the process running the server. Each contact gets a subdirectory.
MEDIA_ROOT=/var/lib/whatsapp-media

# How many days inbound media is kept before automatic cleanup.
MEDIA_RETENTION_DAYS=365

# Pin a specific Meta Graph API version (default is whatever the client picks).
#META_API_VERSION=v21.0

# Timezone used for "yesterday" in /api/admin/digest-yesterday. Default UTC.
# Use any IANA name, e.g. 'America/New_York', 'Europe/London'.
#DIGEST_TIMEZONE=UTC

# ═════════════════════════════════════════════════════════════════════════════
# Webhook Forward plugin (OPTIONAL — feeds inbound payloads to an external URL)
# ═════════════════════════════════════════════════════════════════════════════

# If set, every inbound message webhook is POSTed to this URL after being
# stored. Useful to drive an external automation (your workflow runner, your
# queue ingest, your AI worker). Disabled if empty.
#WEBHOOK_FORWARD_URL=https://your-automation.example.com/webhook/wa-inbound

# Per-request timeout for the forward (milliseconds, default 15000).
#WEBHOOK_FORWARD_TIMEOUT_MS=15000

# Number of retries with exponential backoff before giving up (default 3).
#WEBHOOK_FORWARD_RETRIES=3

# ═════════════════════════════════════════════════════════════════════════════
# SMS Fallback plugin (OPTIONAL — sends SMS when WhatsApp delivery fails)
# ═════════════════════════════════════════════════════════════════════════════

# Which driver to use. 'disabled' or empty = plugin off. 'twilio' = use the
# reference Twilio driver (see src/plugins/sms-fallback/drivers/twilio.js).
#SMS_FALLBACK_DRIVER=disabled

# Comma-separated list of E.164 prefixes whose recipients are eligible for the
# SMS fallback. Empty = no recipients eligible (effectively disables fallback
# even when a driver is configured). Example: "+1,+44".
#SMS_FALLBACK_ALLOWLIST_PREFIXES=

# How long the gateway waits past send time before a message is considered
# "past deadline" and ready for the fallback (milliseconds, default 300000 = 5 min).
#SMS_FALLBACK_DEADLINE_MS=300000

# Twilio driver (only required when SMS_FALLBACK_DRIVER=twilio)
#TWILIO_ACCOUNT_SID=
#TWILIO_AUTH_TOKEN=
#TWILIO_FROM=+15555550100

# ═════════════════════════════════════════════════════════════════════════════
# Fallback Watcher hook (OPTIONAL — triggers an external workflow on failed
# delivery; used by /api/admin/fallback-log to record decisions)
# ═════════════════════════════════════════════════════════════════════════════

# An HTTP endpoint called when a delivery status arrives indicating the
# message did not reach the recipient and the row is eligible for fallback.
# The downstream worker is responsible for actually calling the SMS provider
# and POSTing back to /api/admin/fallback-log.
#FALLBACK_WATCHER_URL=
#FALLBACK_WATCHER_TOKEN=
