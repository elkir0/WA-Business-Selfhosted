{
  "name": "wa-business-selfhosted",
  "version": "0.2.0",
  "description": "Open-source self-hostable gateway for the WhatsApp Business Cloud API.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elkir0/WA-Business-Selfhosted.git"
  },
  "bugs": {
    "url": "https://github.com/elkir0/WA-Business-Selfhosted/issues"
  },
  "homepage": "https://github.com/elkir0/WA-Business-Selfhosted#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently -k -n srv,ui 'node --watch src/server.js' 'vite'",
    "build": "vite build",
    "test": "node --test 'tests/*.test.js'",
    "set-password": "node scripts/set-password.js",
    "scan": "./scripts/scan-secrets.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "express-rate-limit": "^8.0.0",
    "form-data": "^4.0.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.0",
    "preact": "^10.24.0",
    "preact-iso": "^2.8.0",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-business",
    "whatsapp-cloud-api",
    "meta",
    "messaging",
    "selfhosted",
    "gateway",
    "express",
    "postgres"
  ]
}
